{
    "name": "ageofgame",
    "productName": "Age of Game",
    "version": "0.1.0",
    "description": "Standalone desktop screen playground game.",
    "main": ".webpack/main",
    "engines": {
        "node": "22.x",
        "npm": ">=10"
    },
    "scripts": {
        "start": "electron-forge start",
        "package": "electron-forge package",
        "make": "electron-forge make --targets=@electron-forge/maker-squirrel,@electron-forge/maker-zip",
        "make:win-x64": "electron-forge make --platform=win32 --arch=x64 --targets=@electron-forge/maker-squirrel,@electron-forge/maker-zip",
        "make:win-arm64": "electron-forge make --platform=win32 --arch=arm64 --targets=@electron-forge/maker-squirrel,@electron-forge/maker-zip",
        "make:store": "electron-forge make --platform=win32 --arch=x64 --targets=@electron-forge/maker-appx",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "game",
        "electron",
        "screen-playground"
    ],
    "author": {
        "name": "gmiez",
        "email": "gabl@inbox.lv"
    },
    "license": "MIT",
    "devDependencies": {
        "@electron-forge/cli": "^7.8.0",
        "@electron-forge/maker-appx": "^7.8.0",
        "@electron-forge/maker-squirrel": "^7.8.0",
        "@electron-forge/maker-zip": "^7.8.0",
        "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
        "@electron-forge/plugin-fuses": "^7.8.0",
        "@electron-forge/plugin-webpack": "^7.8.0",
        "@electron/fuses": "^1.8.0",
        "@types/node": "^22.10.5",
        "@types/react": "^19.0.12",
        "@types/react-dom": "^19.0.4",
        "@typescript-eslint/eslint-plugin": "^8.28.0",
        "@typescript-eslint/parser": "^8.28.0",
        "@vercel/webpack-asset-relocator-loader": "1.7.0",
        "css-loader": "^6.11.0",
        "electron": "35.7.5",
        "eslint": "^9.23.0",
        "fork-ts-checker-webpack-plugin": "^7.3.0",
        "node-loader": "^2.1.0",
        "style-loader": "^3.3.4",
        "ts-loader": "^9.5.2",
        "typescript": "^5.3.0",
        "webpack": "^5.108.3",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "electron-squirrel-startup": "^1.0.1",
        "lucide-react": "^0.554.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    }
}
